{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@aroha-astrology/shared": ["src/lib/shared/index.ts"],
      "@aroha-astrology/shared/*": ["src/lib/shared/*"]
    }
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "scripts/**/*",
    "drizzle.config.ts",
    "tsup.config.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/db/migrations",
    "src/lib/astro-engine",
    "src/lib/shared"
  ]
}
