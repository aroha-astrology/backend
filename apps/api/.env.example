# Telegram bot notifications — create a bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# NVIDIA NIM API — get key at https://build.nvidia.com
NVIDIA_NIM_API_KEY=nvapi-...
# Additional pooled keys — scanned dynamically as NVIDIA_NIM_API_KEY_2..NVIDIA_NIM_API_KEY_20.
# All keys (including NVIDIA_NIM_REPORT_API_KEY) share one pool. Selection picks
# the least-busy live key per request; a failed key falls through to the next-least-busy.
# Adding more capacity is a Vercel-env change only — no code change needed.
NVIDIA_NIM_API_KEY_2=
NVIDIA_NIM_API_KEY_3=
NVIDIA_NIM_API_KEY_4=
NVIDIA_NIM_API_KEY_5=
NVIDIA_NIM_API_KEY_6=
# Reports/analysis model (high quality, Free Endpoint on NVIDIA NIM)
# NOTE: nvidia/llama-3.3-nemotron-super-49b-v1 was moved to Downloadable-only
# in May 2026. mistralai/mistral-nemotron is the current hosted replacement.
NVIDIA_NIM_MODEL=mistralai/mistral-nemotron
# Comma-separated text-model fallbacks tried in order when the primary model
# returns a model-side outage (HTTP 400 "DEGRADED", 404 "Not found for
# account", or 500 "Inference connection error" / urn:inference-connection).
# Key rotation cannot recover from these — every key hits the same NVIDIA
# function ID. Leave blank to disable model fallback.
NVIDIA_NIM_MODEL_FALLBACKS=meta/llama-3.3-70b-instruct,mistralai/mixtral-8x22b-instruct-v0.1
# Vision model (auto-selected when messages contain images — palm reading)
# Llama 4 Maverick replaced llama-3.2-90b-vision on 2026-05-12 (stronger native
# multimodal reasoning; Qwen2.5-VL and the entire Qwen/Pixtral/Phi-3.5 vision
# lineage were pulled from NIM's Free Endpoint).
NVIDIA_NIM_VISION_MODEL=meta/llama-4-maverick-17b-128e-instruct
# Comma-separated vision-model fallbacks (same semantics as the text list).
NVIDIA_NIM_VISION_MODEL_FALLBACKS=
# Voice/streaming model (fast, low latency)
NVIDIA_NIM_VOICE_MODEL=meta/llama-3.1-8b-instruct
# TTS model — if NVIDIA supports audio/speech endpoint; omit to use default
# NVIDIA_NIM_TTS_MODEL=nvidia/tts-fastpitch-hifigan

# Internal key for background processing — REQUIRED, no default in production
# Generate with: openssl rand -hex 32
# NEVER leave this as the example value
INTERNAL_PROCESS_KEY=CHANGE_ME_use_openssl_rand_hex_32

# Vercel cron auth — must match the CRON_SECRET set in Vercel env vars
# Generate with: openssl rand -hex 32
CRON_SECRET=CHANGE_ME_use_openssl_rand_hex_32

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
# Webhook secret — set in Razorpay dashboard (Webhooks → Add) and copy here.
# Without this, /api/webhooks/razorpay rejects all events.
RAZORPAY_WEBHOOK_SECRET=

SARVAM_API_KEY=your_sarvam_api_key

# ElevenLabs — primary TTS for voice-mode chat. Voice picks from a matrix
# of (astrologer gender × user language). Falls back to Google Translate TTS,
# then Edge TTS (Indian neural voices, gender-matched).
# Get a key at https://elevenlabs.io/app/settings/api-keys.
ELEVENLABS_API_KEY=
# Model: turbo_v2_5 = ~300ms latency, multilingual_v2 = higher quality slower.
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Per-(gender, language) voice ID overrides. Defaults:
#   Male all langs    : "Bill" pqHfZKP75CvOlQylNhV4 (mature warm, multilingual)
#   Female all langs  : "Charlotte" XB0fDUnXU5powFXDhCwa (warm storyteller, multilingual)
# For TRUE Indian-English / Indian-Hindi accent, clone a native voice in
# ElevenLabs (Voice Lab → Instant Voice Clone with 1 min of sample audio)
# and paste its voice_id below. The defaults above are American-accented
# multilingual voices — they speak Hindi/Tamil/etc but with foreign accent.
ELEVENLABS_VOICE_MALE_EN=
ELEVENLABS_VOICE_MALE_HI=
ELEVENLABS_VOICE_MALE_BN=
ELEVENLABS_VOICE_MALE_TA=
ELEVENLABS_VOICE_MALE_TE=
ELEVENLABS_VOICE_MALE_MR=
ELEVENLABS_VOICE_FEMALE_EN=
ELEVENLABS_VOICE_FEMALE_HI=
ELEVENLABS_VOICE_FEMALE_BN=
ELEVENLABS_VOICE_FEMALE_TA=
ELEVENLABS_VOICE_FEMALE_TE=
ELEVENLABS_VOICE_FEMALE_MR=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Firebase Auth (phone OTP) ──────────────────────────────────────────────────
# Create a dedicated Firebase project at https://console.firebase.google.com
# Enable Phone sign-in: Authentication → Sign-in method → Phone
# Add authorized domains: your production domain + localhost
# Add test numbers for dev (e.g. +919999999999 / OTP 123456) to skip real SMS
#
# Server-only — service account for firebase-admin token verification
FIREBASE_AUTH_PROJECT_ID=your-firebase-auth-project-id
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Client-side — Firebase web SDK config (safe to expose publicly)
NEXT_PUBLIC_FIREBASE_AUTH_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_AUTH_PROJECT_ID=your-firebase-auth-project-id
NEXT_PUBLIC_FIREBASE_AUTH_APP_ID=1:...:web:...

# Upstash Redis REST — for rate limiting on /api/credits/* and /api/chat.
# Free tier at upstash.com (Mumbai region recommended). When unset, rate
# limiting is silently disabled (fail-open).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Web Push (VAPID) — generate once with: npx web-push generate-vapid-keys
# If left blank, push notifications are silently disabled.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# AWS Bedrock — palm reading pipeline (replaces NVIDIA NIM for palm analysis)
# Region must be us-east-1 (required for Nova Canvas; Claude 3.5 Sonnet v2 also available there)
# IAM permissions needed: bedrock:InvokeModel + bedrock:InvokeModelWithResponseStream
# on anthropic.claude-3-5-sonnet-20241022-v2:0 and amazon.nova-canvas-v1:0
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
