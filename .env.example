# --- server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
# comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://13.232.179.137:3000,https://frontend-kappa-livid-13.vercel.app,http://frontend-git-staging-aroha-projects.vercel.app,https://app.arohaastrology.in

# --- database (Supabase Postgres) ---
# Use the pooled connection string from Supabase ("Connection pooling" tab).
# For local development you can also point this at a local Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aroha_astrology

# --- Supabase (for Storage, etc — DB is reached via DATABASE_URL above) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

# --- Firebase Admin (service account) ---
# Get the key from the Firebase console → Project settings → Service accounts → Generate new private key.
# Preferred: drop the JSON into ./secrets/ (gitignored) and point at it.
# The path is resolved from the process working directory (run the server from backend/).
# NOTE: when set, this takes precedence over the three FIREBASE_* vars below.
#FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/your-project-firebase-adminsdk.json

# Alternative (e.g. on hosts where files are awkward): provide the three fields instead.
# Paste the private key with \n for newlines, or wrap a real multi-line key in double quotes.
#FIREBASE_PROJECT_ID=your-firebase-project-id
#FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
#FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# Web app API key (NOT secret — ships in clients). Needed only for scripts/dev-token.ts.
# Firebase console → Project settings → General → Your apps → Web app → apiKey.
FIREBASE_WEB_API_KEY=replace-me

# Google Play Billing (Android in-app purchases) — optional until you've set
# up a service account in Google Cloud with Play Console API access.
#GOOGLE_PLAY_SERVICE_ACCOUNT_PATH=./secrets/your-project-play-billing.json
#GOOGLE_PLAY_PROJECT_ID=your-gcp-project-id
#GOOGLE_PLAY_CLIENT_EMAIL=play-billing@your-project.iam.gserviceaccount.com
#GOOGLE_PLAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#GOOGLE_PLAY_PACKAGE_NAME=com.aroha.astrology

# --- Gemini (sole LLM provider — required for LLM features: forecast generation, chat) ---
GEMINI_API_KEY=replace-me
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Field-level encryption (birth data, gotra, chat transcripts) ---
# Generate with: openssl rand -base64 32
# Must be set before deploying the encryption migration — see the rollout
# notes in src/db/migrations for the backfill step that has to run first.
#ENCRYPTION_KEY=replace-me
#ENCRYPTION_HASH_KEY=replace-me

# --- Operations ---
#CRON_SECRET=replace-me
#TELEGRAM_BOT_TOKEN="1234567890:ABCD..."
#TELEGRAM_ALERT_CHAT_ID="-1001234567890"
# Extra admin chat IDs allowed to run bot commands, comma-separated (besides TELEGRAM_ALERT_CHAT_ID)
# Admin tier: every command, including /delete and /broadcast.
#TELEGRAM_ADMIN_CHAT_IDS="111111111,222222222"
# Read-only tier: /stats /users /user /search /jobs /coupons only.
#TELEGRAM_READONLY_CHAT_IDS="333333333"
# Extra recipients for the chat-downvote alert only, comma-separated (besides TELEGRAM_ALERT_CHAT_ID) — does NOT grant bot command access
#TELEGRAM_DOWNVOTE_EXTRA_CHAT_IDS="5770807345"
#TELEGRAM_WEBHOOK_SECRET="your_webhook_secret_here"
# Nightly horoscope batch skips users with no activity in this many days (default 7).
#HOROSCOPE_ACTIVE_WINDOW_DAYS=7
