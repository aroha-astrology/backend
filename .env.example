# =============================================================================
# Aroha Astrology Backend — environment variables
# Copy to .env.local for local dev. Production values live in Vercel.
# NEVER commit a populated .env file.
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── NVIDIA NIM — pooled key set (NVIDIA_NIM_API_KEY_2..NVIDIA_NIM_API_KEY_20)
# Scanner picks least-busy live key per request; failed keys fall through.
# Add more keys in Vercel env only — no code change needed.
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_API_KEY_2=
NVIDIA_NIM_API_KEY_3=
NVIDIA_NIM_API_KEY_4=
NVIDIA_NIM_API_KEY_5=
NVIDIA_NIM_MODEL=mistralai/mistral-nemotron
NVIDIA_NIM_MODEL_FALLBACKS=meta/llama-3.3-70b-instruct,mistralai/mixtral-8x22b-instruct-v0.1
NVIDIA_NIM_VISION_MODEL=meta/llama-4-maverick-17b-128e-instruct
NVIDIA_NIM_VOICE_MODEL=meta/llama-3.1-8b-instruct

# ── Google Gemini / Groq (LLM fallbacks) ─────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Razorpay (payments) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Sarvam (Indian-language TTS) ─────────────────────────────────────────────
SARVAM_API_KEY=

# ── ElevenLabs (English/multilingual TTS for voice chat) ─────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Internal / cron auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_PROCESS_KEY=
CRON_SECRET=

# ── Upstash Redis (rate limiting) ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Web Push (VAPID, server-side) ────────────────────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@arohaastrology.com

# ── AWS Bedrock (palm reading pipeline) ──────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Firebase Auth (phone OTP — server-side verification) ─────────────────────
FIREBASE_AUTH_PROJECT_ID=
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=

# ── Apollo.io (user enrichment, optional) ────────────────────────────────────
APOLLO_API_KEY=

# ── Telegram alerts (optional ops notifications) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App URL (for absolute redirects from server) ─────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
