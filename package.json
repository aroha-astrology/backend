{
  "name": "@aroha-astrology/backend",
  "private": true,
  "version": "0.1.0",
  "description": "Aroha Astrology backend — Next.js API + astro-engine + shared. Source of truth for all crons and DB migrations.",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    },
    "patchedDependencies": {
      "swisseph-wasm@0.0.5": "patches/swisseph-wasm@0.0.5.patch"
    }
  }
}
