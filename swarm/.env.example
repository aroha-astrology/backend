# ---------------------------------------------------------------------------
# Aroha Swarm — environment configuration (copy to .env for local dev)
# ---------------------------------------------------------------------------

# Runtime
AROHA_ENV=dev                      # dev | staging | prod
AROHA_REGION=ap-south-1            # asserted at startup in prod (data localization)

# --- Auth (Firebase) ---
# Path to the Firebase service-account JSON. Leave blank in dev to enable the
# DEV auth bypass (see app/middleware/auth.py). NEVER leave blank in prod.
FIREBASE_CREDENTIALS_FILE=
# When true (dev only), unverified requests are accepted as DEV_USER_ID.
AROHA_DEV_AUTH_BYPASS=true
DEV_USER_ID=dev-user-0001

# --- NVIDIA NIM (LLM) ---
NVIDIA_NIM_API_KEY=
# Additional pooled keys: NVIDIA_NIM_API_KEY_2 .. NVIDIA_NIM_API_KEY_20
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Tiered model routing — each profile resolves to its purpose-fit model
MODEL_ROUTING=meta/llama-3.1-8b-instruct              # fast classification / intent
MODEL_STRUCTURED=mistralai/mixtral-8x22b-instruct      # deterministic JSON (forecasts)
MODEL_CONVERSATIONAL=meta/llama-3.1-70b-instruct       # warm streamed chat (Scholar)
NIM_SUMMARIZER_MODEL=meta/llama-3.1-8b-instruct        # chat rolling summary (cheap)

# --- Astrology engine ---
AYANAMSA=lahiri
# Optional path to Swiss Ephemeris data files. If unset, the Moshier built-in
# ephemeris is used (no data files; good enough for dev, pin SE files for prod).
SE_EPHE_PATH=
ENGINE_RULE_VERSION=v1

# --- Supabase (Phase 2.5+) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=                      # postgres URL for Alembic

# --- Redis (queue / locks / cache / rate-limit) (Phase 2.5+) ---
REDIS_URL=redis://localhost:6379/0

# --- Ops ---
CRON_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
SENTRY_DSN=
